                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[REPORTE DE CUENTAS BANCARIAS]]></text>
            </staticText>
            <staticText>
                <reportElement x="15" y="38" width="400" height="16" forecolor="#A8C8E8"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Resumen consolidado de cuentas agrupadas por entidad bancaria]]></text>
            </staticText>
            <staticText>
                <reportElement x="560" y="22" width="60" height="16" forecolor="#A8C8E8"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Generado:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="622" y="22" width="175" height="16" forecolor="#E8A020"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ENCABEZADO DE PÁGINA -->
    <pageHeader>
        <band height="18" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="802" height="16" forecolor="#888888"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <text><![CDATA[Sistema Bancario — Reporte Interno Confidencial]]></text>
            </staticText>
