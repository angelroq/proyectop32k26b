    <!-- DETALLE -->
    <detail>
        <band height="24" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="23" backcolor="#EBF5FB" forecolor="#EBF5FB" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{RowNumber} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement fill="Solid"><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="802" height="23" backcolor="#FFFFFF" forecolor="#FFFFFF" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{RowNumber} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement fill="Solid"><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="3" height="23" backcolor="#2E86C1" forecolor="#2E86C1"/>
                <graphicElement fill="Solid"><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle radius="6">
                <reportElement x="5" y="4" width="36" height="15" backcolor="#2E86C1" forecolor="#2E86C1"/>
                <graphicElement fill="Solid"><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="5" y="4" width="36" height="15" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANid}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="45" y="0" width="155" height="23" forecolor="#1C2833"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANnumerocuenta}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00" isBlankWhenNull="true">
                <reportElement x="200" y="0" width="110" height="23" forecolor="#1A5276"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANsaldoactual}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="310" y="0" width="120" height="23" forecolor="#555555"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{CBANfechaapertura} != null
                        ? new java.text.SimpleDateFormat("dd MMM yyyy", new java.util.Locale("es","GT"))
                              .format($F{CBANfechaapertura})
                        : ""]]>
                </textFieldExpression>
            </textField>
            <rectangle radius="5">
                <reportElement x="453" y="5" width="34" height="14" backcolor="#E8A020" forecolor="#E8A020"/>
