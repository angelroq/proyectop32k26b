    <!-- ENCABEZADO DE COLUMNAS -->
    <columnHeader>
        <band height="30" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="30" backcolor="#1A5276" forecolor="#1A5276"/>
