	<style name="Detail" fontName="Arial" fontSize="12"/>
	<queryString>
		<![CDATA[SELECT 
    m.Mccfecha AS 'FECHA', 
    m.Mccconcepto AS 'CONCEPTO', 
    t.TTnombretipo AS 'TIPO_TRANSACCION',
    -- Columnas separadas para análisis visual claro 
    CASE WHEN m.Mcctipo = 'ABONO' THEN m.Mccmonto ELSE 0 END AS 'INGRESOS', 
    CASE WHEN m.Mcctipo = 'CARGO' THEN m.Mccmonto ELSE 0 END AS 'EGRESOS', 
    -- Monto con signo para cálculos de saldo 
    CASE WHEN m.Mcctipo = 'CARGO' THEN (m.Mccmonto * -1) ELSE m.Mccmonto END AS 'MONTO_REAL' 
FROM movimientoscc m 
INNER JOIN cattipotransaccion t ON m.TTid = t.TTid 
WHERE m.Acrecodigo = 1  
  AND m.Mccmodulo = 'BANCOS' 
  AND m.Mccfecha BETWEEN '2025-01-01' AND '2026-12-31' -- <--- Fechas reales
ORDER BY m.Mccfecha ASC;]]>
	</queryString>
	<field name="FECHA" class="java.time.LocalDateTime"/>
	<field name="CONCEPTO" class="java.lang.String"/>
	<field name="TIPO_TRANSACCION" class="java.lang.String"/>
	<field name="INGRESOS" class="java.math.BigDecimal"/>
	<field name="EGRESOS" class="java.math.BigDecimal"/>
	<field name="MONTO_REAL" class="java.math.BigDecimal"/>
